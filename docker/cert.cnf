[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_ext
[dn]
C = CN
O = IMQUIC
CN = imquic.com  # 这里可以是任意域名
[v3_ext]
subjectAltName = @alt_names
basicConstraints = CA:FALSE
keyUsage = keyEncipherment, digitalSignature
extendedKeyUsage = serverAuth
[alt_names]
IP.1 = 127.0.0.1
#IP.2 = x.x.x.x
DNS.1 = localhost
